# MediVault — Root Environment Variables
# Copy this to .env and fill in your values

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/medivault_prod?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_64_char_jwt_secret
JWT_REFRESH_SECRET=your_64_char_refresh_secret

# AES-256 Encryption (64 hex chars = 32 bytes)
AES_ENCRYPTION_KEY=your_64_char_hex_key

# URLs
CLIENT_URL=http://localhost
SERVER_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# App
NODE_ENV=production
LOG_LEVEL=info
