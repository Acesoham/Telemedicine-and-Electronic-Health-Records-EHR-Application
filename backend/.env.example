# =============================================================================
# MediVault Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# MongoDB Atlas
# -----------------------------------------------------------------------------
# Development
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/medivault_dev?retryWrites=true&w=majority
# Staging (override in staging environment)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/medivault_staging?retryWrites=true&w=majority
# Production (override in production environment)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/medivault_prod?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_64_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_here_minimum_64_characters_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# AES-256 Encryption
# -----------------------------------------------------------------------------
# Must be exactly 64 hex characters (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# -----------------------------------------------------------------------------
# File Upload
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_DIR=./logs
